# Environnement (development | production)
NODE_ENV=development

# Serveur
PORT=3000
ALLOWED_ORIGIN=http://localhost:5173

# Base de données MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=fo_user
DB_PASSWORD=your_secure_password
DB_NAME=france_organes

# JWT
JWT_SECRET=your_very_long_random_secret_here_min_32_chars
JWT_REFRESH_SECRET=another_very_long_random_secret_here_min_32_chars

# SMTP (email contact)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=contact@franceorganes.fr
SMTP_PASS=your_smtp_password
CONTACT_EMAIL=contact@franceorganes.fr
